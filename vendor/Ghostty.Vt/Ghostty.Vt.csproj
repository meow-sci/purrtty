<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Vendored copy of libghostty-vt-dotnet's `Ghostty.Vt` binding. See README.md
    for provenance + license. purrtty owns this copy and extends it (selection,
    configurable scrollback, default cursor style/blink, batched cell reads).

    Inherits net10.0 / Nullable / ImplicitUsings from the repo-root
    Directory.Build.props. We deliberately relax a couple of repo-wide policies
    for this third-party-derived code so vendored sources build cleanly.
  -->
  <PropertyGroup>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>Ghostty.Vt</RootNamespace>
    <AssemblyName>Ghostty.Vt</AssemblyName>
    <IsAotCompatible>true</IsAotCompatible>

    <!-- Vendored sources are not held to purrtty's warnings-as-errors / XML-doc policy. -->
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <!-- CA2255: ModuleInitializer in a library is intentional here (auto-registers the
         native resolver). IL3000: KSA is not a single-file app, so Assembly.Location is valid. -->
    <NoWarn>$(NoWarn);CS1591;CA2255;IL3000</NoWarn>
  </PropertyGroup>

  <!-- Sources live under src/ to keep the binding visually separate from the csproj + native. -->
  <PropertyGroup>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="src/**/*.cs" />
  </ItemGroup>

  <!-- Tests reach internal helpers (matches upstream binding). -->
  <ItemGroup>
    <InternalsVisibleTo Include="Ghostty.Vt.Tests" />
    <InternalsVisibleTo Include="purrTTY.Terminal" />
    <InternalsVisibleTo Include="purrTTY.Terminal.Tests" />
  </ItemGroup>

  <!--
    Native libghostty-vt, one shared library per supported RID, checked into
    source control under native/<rid>/ (build commands in README.md). ALL of
    them are copied flat next to the built assembly on every build, regardless
    of host OS — the per-platform filenames (libghostty-vt.dylib /
    ghostty-vt.dll / libghostty-vt.so) never collide, and NativeLibraryResolver
    picks the one matching the running OS at runtime. A build from any host
    therefore produces one platform-agnostic output that runs on macOS,
    Windows, and Linux (the GameMod project copies the same files beside
    purrTTY.GameMod.dll for KSA's plugin ALC).

    These MUST be the shared libraries (e.g. zig-out/bin/ghostty-vt.dll) — NOT
    the static archive (ghostty-vt-static.lib) nor the import lib
    (ghostty-vt.lib); neither can be loaded at runtime by P/Invoke.

    If two RIDs of the same OS are ever added (osx-x64, linux-arm64, ...) the
    flat filenames collide; switch to the runtimes/<rid>/native output layout,
    which NativeLibraryResolver already probes.
  -->
  <ItemGroup>
    <None Include="native/osx-arm64/libghostty-vt.dylib" Link="libghostty-vt.dylib">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="native/win-x64/ghostty-vt.dll" Link="ghostty-vt.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="native/linux-x64/libghostty-vt.so" Link="libghostty-vt.so">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
